generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model comments {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  post_id    Int?
  content    String
  created_at DateTime? @default(now()) @db.Timestamp(6)
  posts      posts?    @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([post_id, created_at(sort: Desc)], map: "idx_comments_post_created")
  @@index([user_id], map: "idx_comments_user_id")
}

model follows {
  id                                Int    @id @default(autoincrement())
  follower_id                       Int?
  following_id                      Int?
  users_follows_follower_idTousers  users? @relation("follows_follower_idTousers", fields: [follower_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_follows_following_idTousers users? @relation("follows_following_idTousers", fields: [following_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([follower_id, following_id])
  @@index([following_id, follower_id], map: "idx_follows_following_follower")
  @@index([following_id], map: "idx_follows_following_id")
}

model likes {
  id      Int    @id @default(autoincrement())
  user_id Int?
  post_id Int?
  posts   posts? @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users   users? @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, post_id])
  @@index([post_id], map: "idx_likes_post_id")
}

model posts {
  id         Int        @id @default(autoincrement())
  user_id    Int?
  content    String
  image_url  String?
  created_at DateTime?  @default(now()) @db.Timestamp(6)
  comments   comments[]
  likes      likes[]
  users      users?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_posts_created_at")
  @@index([user_id, created_at(sort: Desc)], map: "idx_posts_user_created")
}

model users {
  id                                  Int        @id @default(autoincrement())
  username                            String
  email                               String     @unique
  password_hash                       String
  bio                                 String?
  avatar_url                          String?
  is_online                           Boolean?   @default(false)
  created_at                          DateTime?  @default(now()) @db.Timestamp(6)
  comments                            comments[]
  follows_follows_follower_idTousers  follows[]  @relation("follows_follower_idTousers")
  follows_follows_following_idTousers follows[]  @relation("follows_following_idTousers")
  likes                               likes[]
  posts                               posts[]

  @@index([is_online], map: "idx_users_is_online")
  @@index([username], map: "idx_users_username")
}
