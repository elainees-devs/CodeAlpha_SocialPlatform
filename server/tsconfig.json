{
  "compilerOptions": {
    /* =========================
       BASIC SETUP
    ========================= */
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",

    /* =========================
       STRICT TYPE SAFETY
    ========================= */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    /* =========================
       MODULE RESOLUTION
    ========================= */
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* =========================
       PRISMA COMPATIBILITY
    ========================= */
    "types": ["node"],
    "skipLibCheck": true,



    /* =========================
       DEBUGGING & OUTPUT
    ========================= */
    "sourceMap": true,
    "removeComments": true,

    /* =========================
       SAFETY
    ========================= */
    "forceConsistentCasingInFileNames": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}